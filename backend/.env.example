# SendR Backend Environment Variables
# Copy this file to .env and adjust values for your local setup.
# All variables use the SENDR_ prefix.

# General
SENDR_ENVIRONMENT=local
SENDR_DATABASE_URL=sqlite+aiosqlite:///./sendr.db
SENDR_SECRET_KEY=change-me-in-production
SENDR_UPLOAD_DIR=./uploads

# CORS (comma-separated list of allowed origins)
SENDR_ALLOWED_ORIGINS=["http://localhost:4200"]

# Email (SMTP)
SENDR_SMTP_HOST=smtp.gmail.com
SENDR_SMTP_PORT=465
SENDR_SMTP_USER=email@gmail.com
SENDR_SMTP_PASSWORD=APP_PASSWORD_HERE
SENDR_SMTP_FROM=email@gmail.com

# File size limits (MB)
SENDR_TEMPORARY_MAX_FILE_SIZE_MB=100
SENDR_FREE_MAX_FILE_SIZE_MB=1024
SENDR_PREMIUM_MAX_FILE_SIZE_MB=10240

# Max files per upload (0 = unlimited)
SENDR_TEMPORARY_MAX_FILES_PER_UPLOAD=10
SENDR_FREE_MAX_FILES_PER_UPLOAD=50
SENDR_PREMIUM_MAX_FILES_PER_UPLOAD=0

# Weekly upload quotas (0 = unlimited)
SENDR_TEMPORARY_MAX_WEEKLY_UPLOADS=3
SENDR_FREE_MAX_WEEKLY_UPLOADS=5
SENDR_PREMIUM_MAX_WEEKLY_UPLOADS=0

# Expiry options per tier (hours)
SENDR_TEMPORARY_EXPIRY_OPTIONS_HOURS=[24,72]
SENDR_FREE_MIN_EXPIRY_HOURS=1
SENDR_FREE_MAX_EXPIRY_HOURS=168
SENDR_PREMIUM_MIN_EXPIRY_HOURS=1
SENDR_PREMIUM_MAX_EXPIRY_HOURS=720

# Download limits per tier (0 = unlimited)
SENDR_TEMPORARY_MAX_DOWNLOADS_OPTIONS=[1,0]
SENDR_FREE_MAX_DOWNLOADS_LIMIT=10
SENDR_PREMIUM_MAX_DOWNLOADS_LIMIT=1000

# Max recipient emails per transfer
SENDR_MAX_RECIPIENT_EMAILS=10

# Passwords per upload (0 = unlimited)
SENDR_TEMPORARY_MAX_PASSWORDS_PER_UPLOAD=1
SENDR_FREE_MAX_PASSWORDS_PER_UPLOAD=3
SENDR_PREMIUM_MAX_PASSWORDS_PER_UPLOAD=0

# Email invites per upload (0 = unlimited, disabled for temporary)
SENDR_TEMPORARY_MAX_EMAILS_PER_UPLOAD=0
SENDR_FREE_MAX_EMAILS_PER_UPLOAD=5
SENDR_PREMIUM_MAX_EMAILS_PER_UPLOAD=0

# File expiration
SENDR_FILE_EXPIRY_DAYS=7
SENDR_FILE_GRACE_PERIOD_DAYS=7

# Token expiry (minutes)
SENDR_TOKEN_EXPIRE_MINUTES=1440
SENDR_VERIFICATION_CODE_EXPIRE_MINUTES=10

# Rate limiting (requests per minute)
SENDR_AUTH_RATE_LIMIT_PER_MINUTE=5

# Altcha CAPTCHA
# SENDR_ALTCHA_HMAC_KEY=  # auto-generated if not set
SENDR_ALTCHA_MAX_NUMBER=100000
SENDR_ALTCHA_EXPIRE_MINUTES=5

# Group download zip threshold
SENDR_GROUP_ZIP_THRESHOLD=3
