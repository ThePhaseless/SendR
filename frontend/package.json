{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "bunx --bun --no-install ng",
    "start": "bunx --bun --no-install ng serve --host 0.0.0.0",
    "build": "bunx --bun --no-install ng build",
    "watch": "bunx --bun --no-install ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "lint": "oxlint --import-plugin --promise-plugin --config oxlintrc.json --ignore-pattern src/app/api src/",
    "lint:fix": "oxlint --import-plugin --promise-plugin --fix --config oxlintrc.json --ignore-pattern src/app/api src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "generate-api": "bunx --bun orval"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "altcha": "^3.0.0-beta.3",
    "postcss": "^8.5.8",
    "rxjs": "~7.8.2",
    "tailwindcss": "4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.2",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@types/jasmine": "~6.0.0",
    "jasmine-core": "~6.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "orval": "^8.6.2",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.22.0",
    "typescript": "^6.0.0"
  }
}
