# Non-sensitive Terraform variables for the live environment.
# Sensitive values (do_token, spaces_access_key, spaces_secret_key) are stored
# in the encrypted file: terraform.tfvars.enc.json
# Edit with: sops terraform.tfvars.enc.json

environment     = "live"
resource_suffix = "dev"
region          = "fra1"
domain_name     = "sendr.email"
create_apex_records = true
k8s_node_count  = 2
k8s_auto_scale  = false
