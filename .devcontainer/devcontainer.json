{
  "name": "SendR",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers-extra/features/uv:1": {},
    "ghcr.io/shyim/devcontainers-features/bun:0": {},
    "ghcr.io/devcontainers/features/node:2": {}
  },
  "mounts": [
    "source=sendr-uv-cache,target=/home/vscode/.cache/uv,type=volume",
    "source=sendr-bun-cache,target=/home/vscode/.bun/install/cache,type=volume"
  ],
  "postCreateCommand": "cd backend && uv sync && cd ../frontend && bun install && cd .. && ./setup-git-hooks.sh",
  "forwardPorts": [
    4200,
    8000
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "angular.ng-template",
        "charliermarsh.ruff",
        "oxc.oxc-vscode",
        "Angular.ng-template",
        "ms-python.python",
        "tamasfe.even-better-toml",
        "oven.bun-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
