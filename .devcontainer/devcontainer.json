{
  "name": "SendR",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers-extra/features/uv:1": {}
  },
  "postCreateCommand": "cd backend && uv sync && cd ../frontend && npm install",
  "forwardPorts": [4200, 8000],
  "customizations": {
    "vscode": {
      "extensions": [
        "angular.ng-template",
        "charliermarsh.ruff",
        "oxc.oxc-vscode"
      ]
    }
  }
}
